---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Introduction from '@components/Introduction.astro';
import SelectedWork from '@components/SelectedWork.astro';
import ProcessStrip from '@components/ProcessStrip.astro';
import FeatureQuote from '@components/FeatureQuote.astro';
import { byOrder } from '../lib/content';

const site = await getEntry('settings', 'site');
const home = await getEntry('pages', 'home');
const testimonials = byOrder(await getCollection('testimonials'));
const services = byOrder(await getCollection('services'));
const featuredServices = services.slice(0, 4);

const hero = home?.data.hero;
const projects = home?.data.gallery;

/* Use Sarah Chen's testimonial — strongest quote. */
const featureTestimonial = testimonials.find((t) => t.id === 'sarah-chen') ?? testimonials[0];

/* Service images: map each service to a suitable project image */
const serviceImages: Record<string, string> = {
  kitchens: '/timberon-cabinets/uploads/_MG_5428.jpg',
  bathrooms: '/timberon-cabinets/uploads/_MG_5515.jpg',
  laundries: '/timberon-cabinets/uploads/_MG_5463.jpg',
  wardrobes: '/timberon-cabinets/uploads/_MG_5445.jpg',
  cabinetry: '/timberon-cabinets/uploads/Ritchies-Mum1.jpg'
};
---

<BaseLayout>
  <!-- ── Hero: full-bleed background image, minimal overlay, nav overlaid ── -->
  <section class="home-hero">
    <div
      class="home-hero__bg"
      style="background-image: url('/timberon-cabinets/uploads/IMG_9733.jpeg')"
      aria-hidden="true"
    ></div>
    <div class="home-hero__blur" aria-hidden="true"></div>
    <div class="home-hero__overlay" aria-hidden="true"></div>
    <div class="home-hero__inner container grid-12">
      <div class="home-hero__content">
        <h1 class="home-hero__h1">{hero?.title ?? 'Craftsmanship built into every detail.'}</h1>
        <p class="home-hero__intro hero-enter hero-enter--intro">{hero?.intro ?? 'Cabinet makers serving Melbourne from our Thomastown workshop.'}</p>
        <div class="home-hero__actions hero-enter hero-enter--actions">
          <a class="home-hero__button" href={hero?.primaryUrl ?? '/contact/'}>
            {hero?.primaryLabel ?? 'Get a quote'} &rarr;
          </a>
          <a class="home-hero__button-secondary" href="/services/">
            View our work &rarr;
          </a>
        </div>
      </div>
    </div>
    <div class="home-hero__scroll hero-enter hero-enter--scroll" aria-hidden="true">&darr;</div>
  </section>

  <!-- ── Introduction: two-column editorial statement ── -->
  <Introduction />

  <!-- ── Selected Work: 3-column project grid ── -->
  <SelectedWork projects={projects} />

  <!-- ── Thin divider between sections ── -->
  <hr class="section-divider" aria-hidden="true" />

  <!-- ── Services: 4 image tiles aligned to the 12-column grid ── -->
  <section class="services-inline">
    <div class="container">
      <p class="section-heading">OUR SERVICES</p>

      <div class="services-inline__track grid-12">
        {featuredServices.map((service) => (
          <a href={`/services/${service.id}/`} class="services-inline__item">
            <div class="services-inline__image-wrap">
              <img
                src={serviceImages[service.id] ?? '/timberon-cabinets/uploads/_MG_5701.jpg'}
                alt={service.data.title}
                loading="lazy"
              />
            </div>
            <div class="services-inline__label-block">
              <span class="services-inline__label">{service.data.title}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Process: split layout, 4 steps + image ── -->
  <ProcessStrip />

  <!-- ── Testimonial: quote-mark block ── -->
  <FeatureQuote
    quote={featureTestimonial?.data?.quote}
    name={featureTestimonial?.data?.name}
    role={featureTestimonial?.data?.role}
  />

  <!-- ── Contact CTA: 3-column layout ── -->
  <section class="cta-split">
    <div class="cta-split__inner container grid-12">
      <div class="cta-split__heading-block">
        <p class="cta-split__kicker">Let's work together</p>
        <h2 class="cta-split__title">Let's create something exceptional.</h2>
      </div>
      <div class="cta-split__action-block">
        <p class="cta-split__text">We're here to help bring your project to life. Get in touch to discuss your ideas or request a quote.</p>
        <a class="cta-split__button" href="/contact/">Request a quote &rarr;</a>
      </div>
      <div class="cta-split__image">
        <img
          src="/timberon-cabinets/uploads/_MG_5683.jpg"
          alt="Custom cabinetry"
          loading="lazy"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ═══════════════════════════════════════════════
     Hero — full-bleed background, nav overlaid
     ═══════════════════════════════════════════════ */

  .home-hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100vh;
    overflow: hidden;
    background: var(--color-overlay-strong);
  }

  /* ── Background photo ── */
  .home-hero__bg {
    position: absolute;
    inset: -8% 0;
    background-position: center 35%;
    background-size: cover;
    background-repeat: no-repeat;
    background-attachment: fixed;
    z-index: 0;
    transform-origin: center center;
    animation: hero-bg-breathe 2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes hero-bg-breathe {
    from { transform: scale(1.07); }
    to   { transform: scale(1); }
  }

  /* ── Progressive blur from left (behind text) ── */
  .home-hero__blur {
    position: absolute;
    inset: 0;
    z-index: 1;
    -webkit-backdrop-filter: blur(5px);
    backdrop-filter: blur(5px);
    -webkit-mask-image: linear-gradient(
      to right,
      black 0%,
      black 35%,
      transparent 70%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      black 0%,
      black 35%,
      transparent 70%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ── Overlay lifts in ── */
  .home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.15) 50%,
      rgba(0, 0, 0, 0.05) 75%
    );
    z-index: 2;
    animation: hero-overlay-in 1.4s ease both;
  }

  @keyframes hero-overlay-in {
    from { opacity: 0.3; }
    to   { opacity: 1; }
  }

  .home-hero__inner {
    position: relative;
    z-index: 2;
    width: min(100% - (var(--gutter) * 2), var(--container));
  }

  .home-hero__content {
    grid-column: 1 / span 5;

  }

  .home-hero__content h1 {
    font-weight: 500;
    font-size: var(--text-3xl);
    line-height: var(--line-tight);
    color: #ffffff;
    margin-bottom: var(--space-5);
    /* hidden until GSAP SplitText runs */
    opacity: 0;
  }



  .home-hero__intro {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.75);
    max-width: 34rem;
    margin-bottom: var(--space-6);
    line-height: 1.75;
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .home-hero__button-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.1rem 0.9rem 1.25rem;
    background: transparent;
    color: #ffffff;
    font-weight: 500;
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    line-height: 1;
    transition: border-color 0.2s ease;
  }

  .home-hero__button-secondary:hover {
    border-color: #ffffff;
  }

  .home-hero__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.1rem 0.9rem 1.25rem;
    background: var(--brand-primary);
    color: #ffffff;
    font-weight: 500;
    font-size: var(--text-base);
    text-decoration: none;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: filter 0.2s ease;
  }

  .home-hero__button:hover {
    filter: brightness(1.15);
  }

  /* ── Scroll indicator: fades in then bounces ── */
  .home-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.4);
    pointer-events: none;
  }

  /* ── Shared entrance keyframe ── */
  @keyframes hero-enter {
    from {
      opacity: 0;
      transform: translateY(36px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Scroll indicator combined animation ── */
  @keyframes hero-scroll-appear-bounce {
    0%   { opacity: 0; transform: translateX(-50%) translateY(0); }
    20%  { opacity: 1; transform: translateX(-50%) translateY(0); }
    60%  { opacity: 1; transform: translateX(-50%) translateY(7px); }
    100% { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .hero-enter {
    opacity: 0;
    animation: hero-enter 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-enter--intro  { animation-delay: 0.55s; }
  .hero-enter--actions { animation-delay: 0.8s; }
  .hero-enter--scroll {
    animation: hero-scroll-appear-bounce 3.2s cubic-bezier(0.22, 1, 0.36, 1) 1.4s both;
    animation-iteration-count: infinite;
  }

  @media (max-width: 820px) {
    .home-hero__bg {
      background-attachment: scroll;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero__bg {
      animation: none;
      transform: none;
      background-attachment: scroll;
    }
    .home-hero__overlay {
      animation: none;
    }
    .home-hero__h1 {
      opacity: 1;
    }

    .hero-enter {
      animation: none;
      opacity: 1;
    }
  }

  /* ── Header overlay: white nav links on the hero ── */

  body:has(.home-hero) .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    border-bottom: none;
    background: transparent;
  }

  body:has(.home-hero) .site-header__nav a {
    color: #ffffff !important;
  }

  body:has(.home-hero) .site-header__nav a:hover,
  body:has(.home-hero) .site-header__nav a[aria-current='page'] {
    color: rgba(255, 255, 255, 0.7) !important;
  }

  body:has(.home-hero) .site-header__cta {
    color: #ffffff !important;
  }

  body:has(.home-hero) .site-header__cta:hover {
    filter: brightness(1.15);
    color: #ffffff !important;
  }

  /* ═══════════════════════════════════════════════
     Services — 4 portrait image tiles, labels below
     ═══════════════════════════════════════════════ */

  .services-inline {
    padding-block: calc(var(--section-y) * 0.75);
  }

  .services-inline__track {
    row-gap: var(--space-6);
  }

  .services-inline__item {
    grid-column: span 3;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .services-inline__image-wrap {
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .services-inline__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .services-inline__item:hover .services-inline__image-wrap img {
    transform: scale(1.04);
  }

  .services-inline__label-block {
    background: var(--color-soft);
    padding: 0.75rem 0.9rem;
  }

  .services-inline__label {
    display: block;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-heading);
  }

  @media (max-width: 900px) {
    .home-hero__content {
      grid-column: 1 / span 7;
    }

    .services-inline__item {
      grid-column: span 6;
    }
  }

  @media (max-width: 600px) {
    .home-hero__content,
    .services-inline__item {
      grid-column: 1;
    }

    .home-hero__content {
      max-width: 100%;
    }

    .home-hero__content h1 {
      font-size: clamp(2.75rem, 14vw, 4rem);
      overflow-wrap: anywhere;
    }

    .home-hero__intro {
      font-size: var(--text-base);
    }
  }

  /* ═══════════════════════════════════════════════
     CTA — 3-column layout
     ═══════════════════════════════════════════════ */

  .cta-split {
    padding-block: 0;
    background: var(--color-section);
    overflow: hidden;
  }

  .cta-split__inner {
    row-gap: var(--space-6);
    align-items: stretch;
    height: clamp(18rem, 22vw, 24rem);
  }

  .cta-split__heading-block {
    grid-column: 1 / span 5;
    align-self: center;
  }

  .cta-split__kicker {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .cta-split__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
    line-height: 1.08;
    margin: 0;
  }

  .cta-split__action-block {
    grid-column: 6 / span 3;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    align-self: center;
  }

  .cta-split__text {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 28rem;
  }

  .cta-split__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.1rem 0.9rem 1.25rem;
    background: var(--brand-primary);
    color: #ffffff;
    font-weight: 500;
    font-size: var(--text-sm);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
    border: none;
    align-self: flex-start;
    transition: filter 0.2s ease;
  }

  .cta-split__button:hover {
    filter: brightness(1.15);
  }

  .cta-split__image {
    grid-column: 9 / span 4;
    overflow: hidden;
    height: 100%;
    margin-right: calc(((100vw - min(100% - (var(--gutter) * 2), var(--container))) / -2) - var(--gutter));
  }

  .cta-split__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 820px) {
    .cta-split__inner {
      height: auto;
      padding-block: var(--section-y-compact);
    }

    .cta-split__heading-block,
    .cta-split__action-block {
      grid-column: 1 / span 6;
    }

    .cta-split__image {
      order: -1;
      grid-column: 7 / span 6;
      aspect-ratio: 4 / 3;
      height: auto;
      margin-right: 0;
    }
  }

  @media (max-width: 720px) {
    .cta-split__heading-block,
    .cta-split__action-block,
    .cta-split__image {
      grid-column: 1;
    }
  }

  /* ── Scroll reveal animations are in theme.css ──
     The IntersectionObserver is provided by lib/reveal.ts.
     For GSAP-powered sequenced reveals, see the <script> below. */
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  import { observeReveal } from '../lib/reveal';

  /* ── CSS scroll reveals (theme.css `.reveal` / `.reveal-image`) ── */
  observeReveal(document);

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Hero h1: line-by-line stagger ── */
  const heroH1 = document.querySelector<HTMLElement>('.home-hero__h1');
  if (heroH1) {
    if (reduceMotion) {
      heroH1.style.opacity = '1';
    } else {
      const heroSplit = SplitText.create(heroH1, { type: 'lines' });

      gsap.fromTo(
        heroSplit.lines,
        { autoAlpha: 0, filter: 'blur(14px)', y: 12 },
        {
          autoAlpha: 1,
          filter: 'blur(0px)',
          y: 0,
          duration: 0.8,
          ease: 'power2.out',
          stagger: 0.14,
          delay: 0.25,
          onStart() { gsap.set(heroH1, { opacity: 1 }); }
        }
      );
    }
  }

  if (!reduceMotion) {
    const staggeredGroups = [
      {
        trigger: '.selected-work__grid',
        items: '.selected-work__card',
        y: 28
      },
      {
        trigger: '.services-inline__track',
        items: '.services-inline__item',
        y: 24
      }
    ];

    /* ── h2/h3 per-letter blur-to-clear reveal ── */
    const headings = gsap.utils.toArray<HTMLElement>('h2, h3');

    for (const heading of headings) {
      const split = SplitText.create(heading, { type: 'words,chars' });

      gsap.fromTo(
        split.chars,
        {
          autoAlpha: 0,
          filter: 'blur(12px)',
          y: 10
        },
        {
          autoAlpha: 1,
          filter: 'blur(0px)',
          y: 0,
          duration: 0.6,
          ease: 'power2.out',
          stagger: 0.02,
          scrollTrigger: {
            trigger: heading,
            start: 'top 85%',
            once: true
          }
        }
      );
    }

    for (const group of staggeredGroups) {
      const trigger = document.querySelector(group.trigger);
      const items = gsap.utils.toArray<HTMLElement>(group.items);

      if (!trigger || items.length === 0) continue;

      gsap.fromTo(
        items,
        {
          autoAlpha: 0,
          y: group.y
        },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.7,
          ease: 'power2.out',
          stagger: 0.1,
          immediateRender: true,
          scrollTrigger: {
            trigger,
            start: 'top 78%',
            once: true
          }
        }
      );
    }
  }
</script>
