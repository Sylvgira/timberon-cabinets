---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Introduction from '@components/Introduction.astro';
import SelectedWork from '@components/SelectedWork.astro';
import ProcessStrip from '@components/ProcessStrip.astro';
import FeatureQuote from '@components/FeatureQuote.astro';
import CTABand from '@components/CTABand.astro';
import { byOrder } from '../lib/content';

const site = await getEntry('settings', 'site');
const home = await getEntry('pages', 'home');
const testimonials = byOrder(await getCollection('testimonials'));
const services = byOrder(await getCollection('services'));

const hero = home?.data.hero;
const projects = home?.data.gallery;

/* Use Sarah Chen's testimonial — strongest quote. */
const featureTestimonial = testimonials.find((t) => t.id === 'sarah-chen') ?? testimonials[0];

/* Service images: map each service to a suitable project image */
const serviceImages: Record<string, string> = {
  kitchens: '/timberon-cabinets/uploads/_MG_5683.jpg',
  bathrooms: '/timberon-cabinets/uploads/_MG_5694.jpg',
  laundries: '/timberon-cabinets/uploads/_MG_5763.jpg',
  wardrobes: '/timberon-cabinets/uploads/_MG_5657.jpg',
  cabinetry: '/timberon-cabinets/uploads/SNY05537-2.jpg'
};
---

<BaseLayout>
  <!-- ── Hero: full-bleed background image, minimal overlay, nav overlaid ── -->
  <section class="home-hero">
    <div
      class="home-hero__bg"
      style="background-image: url('/timberon-cabinets/uploads/IMG_9733.jpeg')"
      aria-hidden="true"
    ></div>
    <div class="home-hero__overlay" aria-hidden="true"></div>
    <div class="home-hero__inner container">
      <div class="home-hero__content">
        <h1 class="reveal">{hero?.title ?? 'Craftsmanship built into every detail.'}</h1>
        <hr class="home-hero__rule" aria-hidden="true" />
        <p class="home-hero__intro reveal">{hero?.intro ?? 'Cabinet makers serving Melbourne from our Thomastown workshop.'}</p>
        <div class="reveal">
          <a class="home-hero__button" href={hero?.primaryUrl ?? '/contact/'}>
            {hero?.primaryLabel ?? 'Get a quote'} &rarr;
          </a>
          <a class="home-hero__button-secondary" href="/services/">
            View our work &rarr;
          </a>
        </div>
      </div>
    </div>
    <div class="home-hero__scroll" aria-hidden="true">&darr;</div>
  </section>

  <!-- ── Introduction: two-column editorial statement ── -->
  <Introduction />

  <!-- ── Selected Work: 3-column project grid ── -->
  <SelectedWork projects={projects} />

  <!-- ── Thin divider between sections ── -->
  <hr class="section-divider" aria-hidden="true" />

  <!-- ── Services: 5 image tiles with labels below ── -->
  <section class="services-inline">
    <div class="container">
      <p class="section-heading">OUR SERVICES</p>

      <div class="services-inline__track">
        {services.map((service) => (
          <a href={`/services/${service.id}/`} class="services-inline__item">
            <div class="services-inline__image-wrap">
              <img
                src={serviceImages[service.id] ?? '/timberon-cabinets/uploads/_MG_5701.jpg'}
                alt={service.data.title}
                loading="lazy"
              />
            </div>
            <div class="services-inline__label-block">
              <span class="services-inline__label">{service.data.title}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Process: split layout, 4 steps + image ── -->
  <ProcessStrip />

  <!-- ── Testimonial: quote-mark block ── -->
  <FeatureQuote
    quote={featureTestimonial?.data?.quote}
    name={featureTestimonial?.data?.name}
    role={featureTestimonial?.data?.role}
  />

  <!-- ── Contact CTA: compact band ── -->
  <CTABand
    variant="band"
    title="Let's create something exceptional."
    text="Tell us about your project and we will arrange a design consultation."
    label="Get a quote"
    href="/contact/"
  />
</BaseLayout>

<style is:global>
  /* ═══════════════════════════════════════════════
     Hero — full-bleed background, nav overlaid
     ═══════════════════════════════════════════════ */

  .home-hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100vh;
    overflow: hidden;
    background: var(--color-overlay-strong);
  }

  .home-hero__bg {
    position: absolute;
    inset: 0;
    background-position: center 35%;
    background-size: cover;
    background-repeat: no-repeat;
    z-index: 0;
  }

  .home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.15) 50%,
      rgba(0, 0, 0, 0.05) 75%
    );
    z-index: 1;
  }

  .home-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .home-hero__content {
    max-width: 38rem;
  }

  .home-hero__content h1 {
    font-weight: 500;
    font-size: var(--text-3xl);
    line-height: var(--line-tight);
    color: #ffffff;
    margin-bottom: var(--space-5);
  }

  .home-hero__intro {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.75);
    max-width: 34rem;
    margin-bottom: var(--space-6);
    line-height: 1.75;
  }

  .home-hero__rule {
    width: 4rem;
    height: 1px;
    margin: var(--space-5) 0 var(--space-6);
    border: none;
    background: rgba(255, 255, 255, 0.35);
  }

  .home-hero__button-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    background: transparent;
    color: #ffffff;
    font-weight: 600;
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    line-height: 1;
    transition: border-color 0.2s ease;
  }

  .home-hero__button-secondary:hover {
    border-color: #ffffff;
  }

  .home-hero__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    background: var(--brand-primary);
    color: #ffffff;
    font-weight: 600;
    font-size: var(--text-base);
    text-decoration: none;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: filter 0.2s ease;
  }

  .home-hero__button:hover {
    filter: brightness(1.15);
  }

  .home-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.4);
    animation: hero-scroll-bounce 2.5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes hero-scroll-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ── Header overlay: transparent nav on the hero ── */

  body:has(.home-hero) .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    border-bottom: none;
    background: transparent;
  }

  body:has(.home-hero) .site-header__brand {
    color: #ffffff;
  }

  body:has(.home-hero) .site-header__nav a {
    color: rgba(255, 255, 255, 0.78);
  }

  body:has(.home-hero) .site-header__nav a:hover,
  body:has(.home-hero) .site-header__nav a[aria-current='page'] {
    color: #ffffff;
  }

  /* ═══════════════════════════════════════════════
     Shared section utilities
     ═══════════════════════════════════════════════ */

  .section-heading {
    margin-bottom: var(--space-6);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .section-divider {
    margin: 0;
    border: none;
    border-top: 1px solid var(--color-border);
    width: min(100% - (var(--gutter) * 2), var(--container));
    margin-inline: auto;
  }

  /* ═══════════════════════════════════════════════
     Services — 5 portrait image tiles, labels below
     ═══════════════════════════════════════════════ */

  .services-inline {
    padding-block: calc(var(--section-y) * 0.75);
  }

  .services-inline__track {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-3);
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .services-inline__image-wrap {
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .services-inline__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .services-inline__label-block {
    background: var(--color-soft);
    padding: 0.75rem 0.9rem;
  }

  .services-inline__label {
    display: block;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-heading);
  }

  @media (max-width: 900px) {
    .services-inline__track {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .services-inline__track {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ═══════════════════════════════════════════════
     Scroll reveal animations
     ═══════════════════════════════════════════════ */

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .reveal--visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes imageReveal {
    from {
      clip-path: inset(0 0 100% 0);
    }
    to {
      clip-path: inset(0 0 0 0);
    }
  }

  .reveal-image {
    clip-path: inset(0 0 100% 0);
    animation: none;
  }

  .reveal-image--visible {
    animation: imageReveal 0.9s ease-out forwards;
  }
</style>

<script>
  /* ── Intersection Observer for scroll reveals ── */
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const el = entry.target;
          if (el.classList.contains('reveal-image')) {
            el.classList.add('reveal-image--visible');
          } else {
            el.classList.add('reveal--visible');
          }
          observer.unobserve(el);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  const revealEls = document.querySelectorAll('.reveal, .reveal-image');
  for (const el of revealEls) {
    observer.observe(el);
  }
</script>
