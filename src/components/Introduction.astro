---
interface Props {
  headline?: string;
  body?: string;
}

const {
  headline = 'Built around materials, precision, and people.',
  body = 'Timberon Cabinets has been designing and building custom cabinetry for Melbourne homes from our Thomastown workshop for over a decade. Every project begins with a conversation — about how you live, how you store, and how you want the space to feel. We handle the full process in-house: consultation, design, manufacture, and installation. No subcontractors, no hand-offs. Just a single team accountable for the result.'
} = Astro.props;
---

<section class="introduction">
  <div class="container">
    <div class="introduction__grid">
      <h2 class="introduction__headline">{headline}</h2>
      <div class="introduction__body">
        <p>{body}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .introduction {
    padding-block: var(--section-y);
  }

  .introduction__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .introduction__headline {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 500;
    line-height: 1.15;
    margin: 0;
    color: var(--color-heading);
  }

  .introduction__body p {
    font-size: var(--text-md);
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 720px) {
    .introduction__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
