---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  site: {
    name: string;
    ctaLabel?: string;
    ctaUrl?: string;
  };
  pathname: string;
}

const { site, pathname } = Astro.props;
const nav: { label: string; href: string; exact?: boolean }[] = [
  { label: 'Work', href: '/services/', exact: true },
  { label: 'Services', href: '/services/' },
  { label: 'About', href: '/about/' },
  { label: 'Process', href: '/#process' },
  { label: 'Contact', href: '/contact/' }
];

const isCurrent = (item: { label: string; href: string; exact?: boolean }) => {
  if (item.href.startsWith('/#')) return false;
  if (item.exact) return pathname === item.href;
  return pathname === item.href || pathname.startsWith(item.href);
};
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label={`${site.name} home`}>
      <img
        class="site-header__logo"
        src="/timberon-cabinets/uploads/brand/tc-logo.png"
        alt="Timberon Cabinets"
        width="1215"
        height="490"
        loading="eager"
      />
    </a>
    <nav class="site-header__nav" aria-label="Primary navigation">
      {nav.map((item) => (
        <a href={item.href} aria-current={isCurrent(item) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
      {site.ctaLabel && site.ctaUrl && (
        <a href={site.ctaUrl} class="site-header__cta">
          {site.ctaLabel}
        </a>
      )}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-page);
  }

  .site-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 5rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .site-header__brand:hover {
    opacity: 0.75;
  }

  .site-header__logo {
    display: block;
    height: 2.4rem;
    width: auto;
  }

  .site-header__nav {
    display: flex;
    gap: var(--space-6);
    align-items: center;
  }

  .site-header__nav a {
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    color: var(--brand-primary);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    background: var(--brand-primary);
    color: #fff !important;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 0.25rem;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .site-header__cta:hover {
    background: var(--brand-primary-hover, var(--brand-primary));
    transform: translateY(-1px);
    color: #fff !important;
  }

  @media (max-width: 760px) {
    .site-header__inner {
      flex-wrap: wrap;
      gap: var(--space-3);
      padding-block: var(--space-3);
      min-height: auto;
    }

    .site-header__logo {
      height: 2rem;
    }

    .site-header__nav {
      flex: 1 1 100%;
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: var(--space-3);
    }

    .site-header__nav a {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
    }

    .site-header__cta {
      font-size: 0.68rem;
      padding: 0.4rem 1rem;
    }
  }
</style>
