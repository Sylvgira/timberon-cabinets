---
interface Props {
  site: {
    name: string;
    email?: string;
    phone?: string;
    address?: string;
    socialLinks?: Array<{ label: string; url: string }>;
  };
  variant?: 'default' | 'dark';
}

const { site, variant = 'default' } = Astro.props;
const year = new Date().getFullYear();
const isDark = variant === 'dark';
---

<footer class:list={['site-footer', isDark && 'site-footer--dark']}>
  <div class="site-footer__inner container">
    <div class="site-footer__brand">
      <a href="/" aria-label={`${site.name} home`}>
        <img
          class="site-footer__logo"
          src="/timberon-cabinets/uploads/brand/tc-logo.png"
          alt="Timberon Cabinets"
          width="1215"
          height="490"
          loading="lazy"
        />
      </a>
    </div>
    <nav class="site-footer__nav" aria-label="Footer navigation">
      <a href="/services/">Work</a>
      <a href="/services/">Services</a>
      <a href="/about/">About</a>
      <a href="/#process">Process</a>
      <a href="/contact/">Contact</a>
    </nav>
    <div class="site-footer__copy">
      <span>&copy; {year} {site.name}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    background: var(--color-page);
    padding-block: var(--space-6);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    align-items: center;
  }

  .site-footer__brand a {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .site-footer__logo {
    display: block;
    height: 2rem;
    width: auto;
    filter: brightness(0);
  }

  .site-footer__nav {
    display: flex;
    gap: var(--space-5);
    justify-content: center;
  }

  .site-footer__nav a {
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-footer__nav a:hover {
    color: var(--brand-primary);
  }

  .site-footer__copy {
    text-align: right;
  }

  .site-footer__copy span {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* --- dark variant --- */

  .site-footer--dark {
    border-top: none;
    background: #111111;
    color: #ffffff;
  }

  .site-footer--dark .site-footer__brand a {
    color: #ffffff;
  }

  .site-footer--dark .site-footer__logo {
    filter: brightness(0) saturate(100%) invert(1);
  }

  .site-footer--dark .site-footer__brand a:hover {
    opacity: 0.65;
  }

  .site-footer--dark .site-footer__nav a {
    color: #ffffff;
  }

  .site-footer--dark .site-footer__nav a:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .site-footer--dark .site-footer__copy span {
    color: rgba(255, 255, 255, 0.45);
  }

  @media (max-width: 660px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-4);
    }

    .site-footer__nav {
      flex-wrap: wrap;
    }

    .site-footer__logo {
      margin-inline: auto;
    }

    .site-footer__copy {
      text-align: center;
    }
  }
</style>
