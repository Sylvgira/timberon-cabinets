---
interface Step {
  label: string;
  description: string;
}

interface Props {
  steps?: Step[];
}

const {
  steps = [
    { label: 'Consultation', description: 'We visit your home, measure the space, and talk through how you want it to work.' },
    { label: 'Design', description: 'CAD drawings and material samples. You review, we refine, you approve.' },
    { label: 'Manufacture', description: 'Built in our Thomastown workshop. Every cut, edge, and joint to specification.' },
    { label: 'Installation', description: 'Fitted by our own team. Clean, on time, and finished to standard.' }
  ]
} = Astro.props;
---

<section class="process-split">
  <div class="container">
    <div class="process-split__header">
      <p class="eyebrow">Our process</p>
      <h2>How we work</h2>
    </div>
    <div class="process-split__layout">
      <div class="process-split__steps">
        {steps.map((step, i) => (
          <div class="process-split__step">
            <span class="process-split__number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="process-split__step-content">
              <h3 class="process-split__label">{step.label}</h3>
              <p class="process-split__desc">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="process-split__divider" aria-hidden="true"></div>
      <div class="process-split__image">
        <img
          src="/timberon-cabinets/uploads/Our-Approach_WEB_MG_5037.jpg"
          alt="Our workshop and craftsmanship"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .process-split {
    padding-block: var(--section-y);
  }

  .process-split__header {
    margin-bottom: var(--space-7);
  }

  .process-split__header h2 {
    margin-bottom: 0;
  }

  .process-split__layout {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: start;
  }

  .process-split__steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    padding-right: var(--space-8);
  }

  .process-split__step {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .process-split__number {
    display: block;
    flex-shrink: 0;
    width: 3rem;
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--brand-primary);
    line-height: 1;
  }

  .process-split__step-content {
    flex: 1;
  }

  .process-split__label {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-2);
    color: var(--color-heading);
  }

  .process-split__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .process-split__divider {
    width: 1px;
    align-self: stretch;
    background: var(--color-border);
    margin: 0;
  }

  .process-split__image {
    padding-left: var(--space-8);
  }

  .process-split__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  @media (max-width: 860px) {
    .process-split__layout {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    .process-split__steps {
      padding-right: 0;
    }

    .process-split__divider {
      display: none;
    }

    .process-split__image {
      padding-left: 0;
    }

    .process-split__image img {
      aspect-ratio: 16 / 9;
    }
  }
</style>
