---
interface Step {
  label: string;
  description: string;
}

interface Props {
  steps?: Step[];
}

const {
  steps = [
    { label: 'Consultation', description: 'We visit your home, measure the space, and talk through how you want it to work.' },
    { label: 'Design', description: 'CAD drawings and material samples. You review, we refine, you approve.' },
    { label: 'Manufacture', description: 'Built in our Thomastown workshop. Every cut, edge, and joint to specification.' },
    { label: 'Installation', description: 'Fitted by our own team. Clean, on time, and finished to standard.' }
  ]
} = Astro.props;
---

<section class="process-strip" id="process">
  <div class="container">
    <div class="process-strip__header">
      <p class="eyebrow">Our process</p>
      <h2>How we work</h2>
    </div>
    <div class="process-strip__grid">
      {steps.map((step, i) => (
        <div class="process-strip__step">
          <span class="process-strip__number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="process-strip__label">{step.label}</h3>
          <p class="process-strip__desc">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-strip {
    padding-block: var(--section-y);
  }

  .process-strip__header {
    margin-bottom: var(--space-7);
  }

  .process-strip__header h2 {
    margin-bottom: 0;
  }

  .process-strip__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .process-strip__step {
    padding: 0 var(--space-5);
    position: relative;
  }

  .process-strip__step + .process-strip__step {
    border-left: 1px solid var(--color-border);
  }

  .process-strip__number {
    display: block;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1;
    margin-bottom: var(--space-4);
    opacity: 0.4;
  }

  .process-strip__label {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-3);
    color: var(--color-heading);
  }

  .process-strip__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 860px) {
    .process-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .process-strip__step:nth-child(3) {
      border-left: none;
    }

    .process-strip__step {
      padding-bottom: var(--space-5);
    }
  }

  @media (max-width: 560px) {
    .process-strip__grid {
      grid-template-columns: 1fr;
    }

    .process-strip__step + .process-strip__step {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-top: var(--space-5);
    }
  }
</style>
