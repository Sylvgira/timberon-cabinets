---
interface Project {
  title: string;
  description?: string;
  imageUrl?: string;
}

interface Props {
  projects?: Project[];
}

const {
  projects = [
    { title: 'Kitchen renovation', description: 'Custom cabinetry, Ivanhoe', imageUrl: '/timberon-cabinets/uploads/_MG_5701.jpg' },
    { title: 'Bathroom vanity', description: 'Slimline joinery, Reservoir', imageUrl: '/timberon-cabinets/uploads/_MG_5694.jpg' },
    { title: 'Laundry fit-out', description: 'Full-height cabinetry, Preston', imageUrl: '/timberon-cabinets/uploads/_MG_5763.jpg' }
  ]
} = Astro.props;
---

<section class="selected-work">
  <div class="container">
    <div class="selected-work__header">
      <p class="section-heading">SELECTED WORK</p>
      <a href="/services/" class="selected-work__all-link">VIEW ALL WORK &rarr;</a>
    </div>

    <div class="selected-work__stack">
      {projects.map((project) => (
        <article class="selected-work__card">
          <div class="selected-work__image-wrap">
            {project.imageUrl ? (
              <img src={project.imageUrl} alt={project.title} loading="lazy" />
            ) : (
              <div class="selected-work__placeholder" aria-hidden="true"></div>
            )}
          </div>
          <div class="selected-work__panel">
            <div class="selected-work__panel-body">
              <h3 class="selected-work__title">{project.title}</h3>
              <p class="selected-work__location">Thomastown, VIC</p>
              <p class="selected-work__description">{project.description ?? ''}</p>
            </div>
            <a class="selected-work__cta" href="/services/">
              VIEW PROJECT &rarr;
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .selected-work {
    padding-block-start: calc(var(--section-y) * 1.2);
    padding-block-end: calc(var(--section-y) * 0.75);
  }

  .selected-work__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-7);
  }

  .selected-work__all-link {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .selected-work__all-link:hover {
    color: var(--color-heading);
  }

  .selected-work__stack {
    display: flex;
    flex-direction: column;
  }

  .selected-work__card {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 0;
    margin-bottom: var(--space-6);
    text-decoration: none;
    color: inherit;
  }

  .selected-work__card:last-child {
    margin-bottom: 0;
  }

  .selected-work__image-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .selected-work__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .selected-work__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border);
  }

  .selected-work__panel {
    padding: var(--space-6);
    background: #F6F3EE;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .selected-work__panel-body {
    flex: 1;
  }

  .selected-work__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: var(--line-h2);
    color: var(--color-heading);
    margin: 0 0 var(--space-3);
  }

  .selected-work__location {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .selected-work__description {
    font-size: var(--text-base);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
  }

  .selected-work__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-end;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    text-decoration: none;
  }

  .selected-work__cta:hover {
    color: var(--brand-primary);
  }

  @media (max-width: 860px) {
    .selected-work__card {
      grid-template-columns: 1fr;
    }

    .selected-work__image-wrap {
      aspect-ratio: 16 / 9;
    }
  }

  @media (max-width: 560px) {
    .selected-work__header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
  }
</style>
