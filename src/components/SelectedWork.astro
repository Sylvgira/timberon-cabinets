---
interface Project {
  title: string;
  description?: string;
  imageUrl?: string;
}

interface Props {
  projects?: Project[];
}

const {
  projects = [
    { title: 'Kitchen renovation', description: 'Custom cabinetry, Ivanhoe', imageUrl: '/timberon-cabinets/uploads/_MG_5701.jpg' },
    { title: 'Bathroom vanity', description: 'Slimline joinery, Reservoir', imageUrl: '/timberon-cabinets/uploads/_MG_5694.jpg' },
    { title: 'Laundry fit-out', description: 'Full-height cabinetry, Preston', imageUrl: '/timberon-cabinets/uploads/_MG_5763.jpg' }
  ]
} = Astro.props;
---

<section class="selected-work">
  <div class="container">
    <div class="selected-work__header">
      <div>
        <h2>Selected work</h2>
      </div>
      <a href="/services/" class="selected-work__all-link">View all work &rarr;</a>
    </div>

    <div class="selected-work__grid">
      {projects.map((project) => (
        <a href="/contact/" class="selected-work__card">
          <div class="selected-work__image-wrap">
            {project.imageUrl ? (
              <img src={project.imageUrl} alt={project.title} loading="lazy" />
            ) : (
              <div class="selected-work__placeholder" aria-hidden="true"></div>
            )}
          </div>
          <div class="selected-work__info">
            <strong class="selected-work__title">{project.title}</strong>
            {project.description && (
              <span class="selected-work__location">{project.description}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .selected-work {
    padding-block: var(--section-y);
    background: var(--color-section);
  }

  .selected-work__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-7);
  }

  .selected-work__header h2 {
    margin-bottom: 0;
  }

  .selected-work__all-link {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .selected-work__all-link:hover {
    color: var(--color-heading);
  }

  .selected-work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .selected-work__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .selected-work__image-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    margin-bottom: var(--space-4);
  }

  .selected-work__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .selected-work__card:hover .selected-work__image-wrap img {
    transform: scale(1.04);
  }

  .selected-work__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border);
  }

  .selected-work__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .selected-work__title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-heading);
  }

  .selected-work__location {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 860px) {
    .selected-work__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .selected-work__grid {
      grid-template-columns: 1fr;
    }

    .selected-work__header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
  }
</style>
